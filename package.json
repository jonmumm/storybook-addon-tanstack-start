{
  "name": "storybook-addon-tanstack-start",
  "version": "0.2.1",
  "description": "Storybook addon for TanStack Start — Vite plugin that stubs server-side imports (createServerFn, server entries, cookies) so stories render without a server",
  "keywords": [
    "storybook",
    "storybook-addon",
    "tanstack",
    "tanstack-router",
    "tanstack-start",
    "testing",
    "vite-plugin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonmumm/storybook-addon-tanstack-start"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    },
    "./preview": {
      "import": "./dist/preview.mjs",
      "require": "./dist/preview.cjs",
      "types": "./dist/preview.d.mts"
    },
    "./plugin": {
      "import": "./dist/plugin.mjs",
      "require": "./dist/plugin.cjs",
      "types": "./dist/plugin.d.mts"
    },
    "./stubs": {
      "import": "./dist/mocks/start-stubs.mjs",
      "require": "./dist/mocks/start-stubs.cjs",
      "types": "./dist/mocks/start-stubs.d.mts"
    }
  },
  "scripts": {
    "check": "vp check",
    "check:fix": "vp check --fix",
    "test": "vp test",
    "build": "vp pack",
    "knip": "knip",
    "verify": "pnpm check && pnpm knip && pnpm test"
  },
  "dependencies": {
    "storybook-addon-tanstack-router": "^0.1.0"
  },
  "devDependencies": {
    "@storybook/react": "^10.3.1",
    "@tanstack/react-router": "^1.168.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "knip": "^6.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plus": "^0.1.13",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@storybook/react": ">=8.0.0",
    "@tanstack/react-router": ">=1.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@storybook/react": {
      "optional": false
    },
    "vite": {
      "optional": false
    }
  },
  "packageManager": "pnpm@10.5.2"
}
